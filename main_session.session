def load_config():
    if os.path.exists(CONFIG_FILE):
        with open(CONFIG_FILE, "r") as f:
            try:
                config_data.update(json.load(f))
            except:
                pass

def save_config():
    with open(CONFIG_FILE, "w") as f:
        json.dump(config_data, f, indent=4)

